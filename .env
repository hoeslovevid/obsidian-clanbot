DISCORD_TOKEN=MTQ2MDEwNzc1MjY1ODQ0MDIyMw.GMa8-V.-LpZ-czTtX_Er7mo2tXuaP3iOWFW-zWnHKCBbE

# Optional: speeds up slash command appearance by syncing to one server.
# If omitted or 0, commands sync globally (can take longer to appear).
GUILD_ID=668419371047190530

MOD_ROLE_NAME=Obsidian Inheritor
TIMEZONE=America/New_York

# Database file (optional)
DB_PATH=obsidian_clanbot.db

# Temp voice category (you already have this)
TEMP_VC_CATEGORY_ID=1460101742912995422
TEMP_VC_CATEGORY_NAME=Temp VCs

# Join-to-create trigger channel name (auto-created on install)
CREATE_VC_NAME=➕ Form Squad

# Auto-setup core text channels if missing
AUTO_SETUP=true

# Optional: if you already have these channels, set IDs here; otherwise AUTO_SETUP creates them by name.
VOICE_PANEL_CHANNEL_ID=0
VOICE_PANEL_CHANNEL_NAME=obsidian-console

COMPLAINTS_CHANNEL_ID=668428468937162764
COMPLAINTS_CHANNEL_NAME=request-help

COMPLAINTS_LOG_CHANNEL_ID=0
COMPLAINTS_LOG_CHANNEL_NAME=docket-ledger

EVENTS_CHANNEL_ID=0
EVENTS_CHANNEL_NAME=ops-board

# Voice cleanup
VOICE_IDLE_DELETE_MINUTES=5
VC_CLEANUP_INTERVAL_MINUTES=2

# Events reminder
EVENT_REMINDER_MINUTES_BEFORE=60
EVENT_REMINDER_LOOP_MINUTES=1
